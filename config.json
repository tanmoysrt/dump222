{
	"listen": {
		"host": "127.0.0.1",
		"port": 8080
	},
	"jwks": {
		"url": "http://127.0.0.1:9100/.well-known/jwks.json",
		"cache_ttl_seconds": 300
	},
	"jwt": {
		"issuer": "press-controlplane",
		"audience": "press-node"
	},
	"allow_http_agents": true,
	"controlplanes": [
		{
			"name": "primary",
			"url": "http://127.0.0.1:9000",
			"prefixes": ["/api/v1/cluster", "/api/v1/events"],
			"jwt_token": "replace-with-node-jwt"
		}
	],
	"authz": {
		"url": "http://127.0.0.1:9200/check",
		"jwt_token": ""
	},
	"socket_dir": "./press-node-agent",
	"admin_socket": "./press-node-agent/node.sock"
}
